<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.riwi.usersystem.HelloController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label text="Login" />

    <TextField fx:id="usernameField" promptText="Usuario" />

    <PasswordField fx:id="passwordField" promptText="Contraseña" />

    <Button onAction="#onLoginClick" text="Iniciar sesión" />

    <Label fx:id="messageLabel" />

</VBox>
